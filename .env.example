# Contentful core settings
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT_ID=master
CONTENTFUL_DELIVERY_TOKEN=

# Optional: use this token for draft/preview content.
CONTENTFUL_PREVIEW_TOKEN=

# Required for the FengBro Table initializer.
CONTENTFUL_MANAGEMENT_TOKEN=

# Optional: locale passed to Contentful queries.
CONTENTFUL_LOCALE=en-US
